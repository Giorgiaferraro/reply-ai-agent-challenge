LANGFUSE_HOST=https://challenges.reply.com/langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override only if you want custom names outside code defaults.
ORCHESTRATOR_MODEL=openai/gpt-4o-mini
HIGH_VALUE_MODEL=anthropic/claude-3-5-sonnet

# Optional: whisper model for audio transcription (tiny, base, small, medium, large)
WHISPER_MODEL=base

# Prevent LiteLLM startup from hanging on remote model-cost-map fetch.
LITELLM_LOCAL_MODEL_COST_MAP=true

# Disable CrewAI interactive traces prompt in terminal runs.
CREWAI_TRACING_ENABLED=false
